# Supabase — required for the app to start
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Public app URL — used by cron emails, password reset, etc.
NEXT_PUBLIC_APP_URL=https://opstrack-xi.vercel.app

# Super-admin emails (CSV) — fallback for app_config.super_admin_emails
# Used by the /admin gate. The DB value (app_config) takes precedence;
# this env var is the backup if the DB row is missing.
SUPER_ADMIN_EMAILS=admin@example.com,backup-admin@example.com

# === Server-only — required for cron job (PR4) ===

# Service role key — bypasses RLS. Used by the cron handler only.
# Get it from Supabase Dashboard → Settings → API → service_role key.
# NEVER expose this to the client. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Cron secret — Vercel sends this in the Authorization header when
# triggering scheduled cron jobs. Generate with `openssl rand -hex 32`.
CRON_SECRET=replace-with-random-32-byte-hex

# Resend (email provider)
RESEND_API_KEY=re_...
EMAIL_FROM=OpsTrack <noreply@yourdomain.al>
